{
  "name": "avosos-launcher",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "author": "Avosos",
  "description": "Universal application launcher — professional workflow orchestration",
  "scripts": {
    "dev": "next dev --port 3100",
    "dev:electron": "concurrently --kill-others \"next dev --port 3100\" \"wait-on http://localhost:3100 && cross-env ELECTRON_DEV_URL=http://localhost:3100 electron .\"",
    "build": "next build",
    "build:electron": "next build && electron-builder",
    "start": "electron .",
    "lint": "eslint",
    "bump": "node scripts/bump-version.js"
  },
  "build": {
    "appId": "com.avosos.launcher",
    "productName": "Avosos Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
